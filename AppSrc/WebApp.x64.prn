38956>>>    Procedure SetActionButtons
38959>>>        tWebNavigateData NavigateData
38959>>>        tWebNavigateData NavigateData
38959>>>        Boolean bHasRecord
38959>>>        Handle hoDD
38959>>>
38959>>>        Get Server to hoDD
38960>>>        Get GetNavigateData to NavigateData
38961>>>        Get HasRecord of hoDD to bHasRecord
38962>>>
38962>>>        // let's hide all buttons and then Show the ones we want
38962>>>        WebSet pbRender of oEditBtn to False
38963>>>        WebSet pbRender of oSaveBtn to False
38964>>>        WebSet pbRender of oCancelChangesBtn to False
38965>>>        WebSet pbRender of oDeleteBtn to False
38966>>>
38966>>>        If (NavigateData.bReadOnly) Begin
38968>>>            WebSet pbRender of oEditBtn to True
38969>>>        End
38969>>>>
38969>>>        Else Begin
38970>>>            WebSet pbRender of oSaveBtn to True
38971>>>            WebSet pbRender of oCancelChangesBtn to True
38972>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38973>>>        End
38973>>>>
38973>>>    End_Procedure
