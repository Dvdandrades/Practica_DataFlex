37558>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37561>>>        WebSet pbRender of oNewButton to True
37562>>>        WebSet pbRender of oDetailButton to True
37563>>>
37563>>>        Case Begin
37563>>>            Case (NavigateData.eNavigateType = nfFromParent)
37565>>>                // If from parent, this is a constrained drill down
37565>>>                Case Break
37566>>>
37566>>>            Case (NavigateData.eNavigateType = nfFromChild)
37569>>>                // If from child, this is a probably a parent lookup from a Zoom
37569>>>                Case Break
37570>>>
37570>>>            Case (NavigateData.eNavigateType = nfFromMain)
37573>>>                // If from main, this is a probably a main-file lookup from a Zoom
37573>>>                WebSet pbRender of oDetailButton to False
37574>>>                Case Break
37575>>>
37575>>>            Case Else // must be nfUndefined
37575>>>                // This may be the start of a drilldown query or this may be used for some kind of custom query.
37575>>>
37575>>>        Case End
37575>>>
37575>>>    End_Procedure
37576>>>
37576>>>
37576>>>End_Object 
