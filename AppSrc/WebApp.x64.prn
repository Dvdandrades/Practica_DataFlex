38376>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38379>>>        Case Begin
38379>>>            Case (NavigateData.eNavigateType = nfFromMain)
38381>>>                // If from main, this is a propbably a main file Select to Zoom.
38381>>>                Case Break
38382>>>
38382>>>            Case (NavigateData.eNavigateType = nfFromParent)
38385>>>                // If from parent, this is a constrained drill down.
38385>>>                Case Break
38386>>>
38386>>>            Case (NavigateData.eNavigateType = nfFromChild)
38389>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38389>>>                Case Break
38390>>>
38390>>>            Case Else // must be nfUndefined
38390>>>
38390>>>        Case End
38390>>>
38390>>>        Send SetActionButtons
38391>>>
38391>>>    End_Procedure
38392>>>
38392>>>End_Object 
