38348>>>    Procedure SetActionButtons
38351>>>        tWebNavigateData NavigateData
38351>>>        tWebNavigateData NavigateData
38351>>>        Boolean bHasRecord
38351>>>        Handle hoDD
38351>>>
38351>>>        Get Server to hoDD
38352>>>        Get GetNavigateData to NavigateData
38353>>>        Get HasRecord of hoDD to bHasRecord
38354>>>
38354>>>        // let's hide all buttons and then Show the ones we want
38354>>>        WebSet pbRender of oEditBtn to False
38355>>>        WebSet pbRender of oSaveBtn to False
38356>>>        WebSet pbRender of oCancelChangesBtn to False
38357>>>        WebSet pbRender of oDeleteBtn to False
38358>>>
38358>>>        If (NavigateData.bReadOnly) Begin
38360>>>            WebSet pbRender of oEditBtn to True
38361>>>        End
38361>>>>
38361>>>        Else Begin
38362>>>            WebSet pbRender of oSaveBtn to True
38363>>>            WebSet pbRender of oCancelChangesBtn to True
38364>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38365>>>        End
38365>>>>
38365>>>    End_Procedure
38366>>>
38366>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
38369>>>        // Close after save
38369>>>        Send NavigateClose Self
38370>>>    End_Procedure
38371>>>
38371>>>    // this will close the view after a delete
38371>>>    Procedure OnViewDeleted Handle hoDDO
38374>>>        Send NavigateClose Self
38375>>>    End_Procedure
