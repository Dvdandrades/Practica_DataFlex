38984>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38987>>>        Case Begin
38987>>>            Case (NavigateData.eNavigateType = nfFromMain)
38989>>>                // If from main, this is a propbably a main file Select to Zoom.
38989>>>                Case Break
38990>>>
38990>>>            Case (NavigateData.eNavigateType = nfFromParent)
38993>>>                // If from parent, this is a constrained drill down.
38993>>>                Case Break
38994>>>
38994>>>            Case (NavigateData.eNavigateType = nfFromChild)
38997>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38997>>>                Case Break
38998>>>
38998>>>            Case Else // must be nfUndefined
38998>>>
38998>>>        Case End
38998>>>
38998>>>        Send SetActionButtons
38999>>>
38999>>>    End_Procedure
