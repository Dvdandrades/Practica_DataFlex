37560>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37563>>>        WebSet pbRender of oNewButton to True
37564>>>        WebSet pbRender of oDetailButton to True
37565>>>
37565>>>        Case Begin
37565>>>            Case (NavigateData.eNavigateType = nfFromParent)
37567>>>                // If from parent, this is a constrained drill down
37567>>>                Case Break
37568>>>
37568>>>            Case (NavigateData.eNavigateType = nfFromChild)
37571>>>                // If from child, this is a probably a parent lookup from a Zoom
37571>>>                Case Break
37572>>>
37572>>>            Case (NavigateData.eNavigateType = nfFromMain)
37575>>>                // If from main, this is a probably a main-file lookup from a Zoom
37575>>>                WebSet pbRender of oDetailButton to False
37576>>>                Case Break
37577>>>
37577>>>            Case Else // must be nfUndefined
37577>>>                // This may be the start of a drilldown query or this may be used for some kind of custom query.
37577>>>
37577>>>        Case End
37577>>>
37577>>>    End_Procedure
