38950>>>    Procedure SetActionButtons
38953>>>        tWebNavigateData NavigateData
38953>>>        tWebNavigateData NavigateData
38953>>>        Boolean bHasRecord
38953>>>        Handle hoDD
38953>>>
38953>>>        Get Server to hoDD
38954>>>        Get GetNavigateData to NavigateData
38955>>>        Get HasRecord of hoDD to bHasRecord
38956>>>
38956>>>        // let's hide all buttons and then Show the ones we want
38956>>>        WebSet pbRender of oEditBtn to False
38957>>>        WebSet pbRender of oSaveBtn to False
38958>>>        WebSet pbRender of oCancelChangesBtn to False
38959>>>        WebSet pbRender of oDeleteBtn to False
38960>>>
38960>>>        If (NavigateData.bReadOnly) Begin
38962>>>            WebSet pbRender of oEditBtn to True
38963>>>        End
38963>>>>
38963>>>        Else Begin
38964>>>            WebSet pbRender of oSaveBtn to True
38965>>>            WebSet pbRender of oCancelChangesBtn to True
38966>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38967>>>        End
38967>>>>
38967>>>    End_Procedure
