38920>>>    Procedure SetActionButtons
38923>>>        tWebNavigateData NavigateData
38923>>>        tWebNavigateData NavigateData
38923>>>        Boolean bHasRecord
38923>>>        Handle hoDD
38923>>>
38923>>>        Get Server to hoDD
38924>>>        Get GetNavigateData to NavigateData
38925>>>        Get HasRecord of hoDD to bHasRecord
38926>>>
38926>>>        // let's hide all buttons and then Show the ones we want
38926>>>        WebSet pbRender of oEditBtn to False
38927>>>        WebSet pbRender of oSaveBtn to False
38928>>>        WebSet pbRender of oCancelChangesBtn to False
38929>>>        WebSet pbRender of oDeleteBtn to False
38930>>>
38930>>>        If (NavigateData.bReadOnly) Begin
38932>>>            WebSet pbRender of oEditBtn to True
38933>>>        End
38933>>>>
38933>>>        Else Begin
38934>>>            WebSet pbRender of oSaveBtn to True
38935>>>            WebSet pbRender of oCancelChangesBtn to True
38936>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38937>>>        End
38937>>>>
38937>>>    End_Procedure
38938>>>
38938>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
38941>>>        // Close after save
38941>>>        Send NavigateClose Self
38942>>>    End_Procedure
38943>>>
38943>>>    // this will close the view after a delete
38943>>>    Procedure OnViewDeleted Handle hoDDO
38946>>>        Send NavigateClose Self
38947>>>    End_Procedure
38948>>>
38948>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38951>>>        Case Begin
38951>>>            Case (NavigateData.eNavigateType = nfFromMain)
38953>>>                // If from main, this is a propbably a main file Select to Zoom.
38953>>>                Case Break
38954>>>
38954>>>            Case (NavigateData.eNavigateType = nfFromParent)
38957>>>                // If from parent, this is a constrained drill down.
38957>>>                Case Break
38958>>>
38958>>>            Case (NavigateData.eNavigateType = nfFromChild)
38961>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38961>>>                Case Break
38962>>>
38962>>>            Case Else // must be nfUndefined
38962>>>
38962>>>        Case End
38962>>>
38962>>>        Send SetActionButtons
38963>>>
38963>>>    End_Procedure
38964>>>
38964>>>End_Object 
