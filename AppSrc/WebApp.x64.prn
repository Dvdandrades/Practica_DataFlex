38978>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38981>>>        Case Begin
38981>>>            Case (NavigateData.eNavigateType = nfFromMain)
38983>>>                // If from main, this is a propbably a main file Select to Zoom.
38983>>>                Case Break
38984>>>
38984>>>            Case (NavigateData.eNavigateType = nfFromParent)
38987>>>                // If from parent, this is a constrained drill down.
38987>>>                Case Break
38988>>>
38988>>>            Case (NavigateData.eNavigateType = nfFromChild)
38991>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38991>>>                Case Break
38992>>>
38992>>>            Case Else // must be nfUndefined
38992>>>
38992>>>        Case End
38992>>>
38992>>>        Send SetActionButtons
38993>>>
38993>>>    End_Procedure
